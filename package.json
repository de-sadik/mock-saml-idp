{
  "name": "mock-saml-idp",
  "version": "1.0.1",
  "description": "Modern mock SAML 2.0 Identity Provider for testing Azure AD, Okta, OneLogin, PingFederate, Auth0, Google Workspace SSO integrations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mock-saml-idp": "dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "start": "node dist/bin.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "saml",
    "saml2",
    "idp",
    "identity-provider",
    "mock",
    "testing",
    "sso",
    "azure-ad",
    "okta",
    "onelogin",
    "auth0",
    "ping-federate",
    "google-workspace"
  ],
  "author": "Sadik Shaikh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/de-sadik/mock-saml-idp.git"
  },
  "bugs": {
    "url": "https://github.com/de-sadik/mock-saml-idp/issues"
  },
  "homepage": "https://github.com/de-sadik/mock-saml-idp#readme",
  "dependencies": {
    "node-forge": "^1.3.2",
    "uuid": "^9.0.1",
    "xml-crypto": "^6.0.1",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "@types/node-forge": "^1.3.14",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
